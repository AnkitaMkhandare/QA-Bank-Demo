# ─── Environment Configuration ────────────────────────────────────────────────────
# Copy this file to .env and customize values for your environment

# Test Environment (qa | staging | production)
TEST_ENV=qa

# Application URLs
BASE_URL=https://qaplayground.com/bank
API_BASE_URL=https://qaplayground.com/api

# Credentials (override defaults)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# VIEWER_USERNAME=viewer
# VIEWER_PASSWORD=viewer123

# ─── Browser Settings ─────────────────────────────────────────────────────────────
HEADLESS=true
SLOW_MO=0
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ─── Test Execution ───────────────────────────────────────────────────────────────
TEST_TIMEOUT=30000
TEST_RETRIES=1

# ─── Feature Flags ───────────────────────────────────────────────────────────────
ENABLE_SCREENSHOTS=true
ENABLE_VIDEO=true
ENABLE_TRACE=true
DEBUG=false

# ─── CI/CD ────────────────────────────────────────────────────────────────────────
# CI=true  (auto-set by GitHub Actions / Jenkins)