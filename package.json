{
  "name": "bank-automation-framework",
  "version": "2.0.0",
  "description": "Professional E2E Test Automation Framework for Banking Application — Playwright + POM + Data-Driven",
  "author": "Ankita Mkhandare",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:smoke": "npx playwright test --grep=\"@smoke|@critical\"",
    "test:regression": "npx playwright test --grep=\"@regression\"",
    "test:headed": "npx playwright test --headed --project=chromium",
    "test:debug": "DEBUG=true npx playwright test --debug --project=chromium",
    "test:parallel": "npx playwright test --workers=4",
    "test:ci": "CI=true npx playwright test",
    "test:admin": "npx playwright test tests/e2e/part1-admin/ --project=chromium --reporter=html",
    "test:admin:showcase": "npx playwright test tests/e2e/part1-admin/flows/admin-showcase.spec.js --project=chromium --reporter=html",
    "test:viewer": "npx playwright test tests/e2e/part2-viewer/ --project=chromium --reporter=html",
    "test:viewer:showcase": "npx playwright test tests/e2e/part2-viewer/flows/viewer-showcase.spec.js --project=chromium --reporter=html",
    "test:rbac": "npx playwright test tests/e2e/cross-role/ --project=chromium --reporter=html",
    "test:login": "npx playwright test tests/e2e/part1-admin/login/ tests/e2e/part2-viewer/login/ --project=chromium --reporter=list",
    "test:accounts": "npx playwright test tests/e2e/part1-admin/accounts/ tests/e2e/part2-viewer/accounts/ --project=chromium --reporter=list",
    "test:transactions": "npx playwright test tests/e2e/part1-admin/transactions/ tests/e2e/part2-viewer/transactions/ --project=chromium --reporter=list",
    "test:negative": "npx playwright test --grep=\"@negative\" --project=chromium --reporter=list",
    "test:security": "npx playwright test tests/security/ --project=chromium --reporter=list",
    "test:security:mfa": "npx playwright test tests/security/mfa-session.spec.js --project=chromium --reporter=list",
    "test:security:encryption": "npx playwright test tests/security/data-encryption.spec.js --project=chromium --reporter=list",
    "test:compliance": "npx playwright test tests/compliance/ --project=chromium --reporter=list",
    "test:compliance:pci": "npx playwright test tests/compliance/pci-dss.spec.js --project=chromium --reporter=list",
    "test:compliance:gdpr": "npx playwright test tests/compliance/gdpr.spec.js --project=chromium --reporter=list",
    "test:database": "npx playwright test tests/database/ --project=chromium --reporter=list",
    "test:resilience": "npx playwright test tests/resilience/ --project=chromium --reporter=list",
    "test:bill-payments": "npx playwright test tests/e2e/part1-admin/transactions/admin-bill-payments.spec.js --project=chromium --reporter=list",
    "test:edge": "npx playwright test --project=edge",
    "test:all-browsers": "npx playwright test --project=chromium --project=firefox --project=webkit --project=edge",
    "test:all": "npx playwright test tests/e2e/ --project=chromium --reporter=html",
    "test:full-suite": "npx playwright test tests/ --project=chromium --reporter=html",
    "report": "npx playwright show-report reports/html-report",
    "report:generate": "npx playwright test --reporter=html",
    "clean": "rimraf reports test-results",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "docker:build": "docker build -t bank-tests .",
    "docker:run": "docker run --rm -v ./reports:/app/reports bank-tests",
    "docker:smoke": "docker-compose --profile smoke up --abort-on-container-exit",
    "docker:full": "docker-compose --profile full up --abort-on-container-exit",
    "setup": "npm install && npx playwright install --with-deps"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {},
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "page-object-model",
    "data-driven",
    "banking",
    "qa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AnkitaMkhandare/QA-Bank-Demo.git"
  }
}